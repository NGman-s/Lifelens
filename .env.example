# Required for backend AI calls
DASHSCOPE_API_KEY=your_api_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Backend runtime
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:8080
MAX_UPLOAD_SIZE_MB=10
THUMBNAIL_RETENTION_DAYS=30
THUMBNAIL_MAX_EDGE=512
THUMBNAIL_QUALITY=70
UPLOAD_STORAGE_LIMIT_MB=3072

# Docker frontend publish port
FRONTEND_PORT=80

# Optional: direct backend origin for non-H5 builds or special local setups
VITE_API_BASE_URL=
