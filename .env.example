# Required for backend AI calls
DASHSCOPE_API_KEY=your_api_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Backend runtime
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:8080
MAX_UPLOAD_SIZE_MB=10
UPLOAD_RETENTION_DAYS=8

# Docker frontend publish port
FRONTEND_PORT=80

# Optional: direct backend origin for non-H5 builds or special local setups
VITE_API_BASE_URL=
